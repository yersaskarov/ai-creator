TELEGRAM_BOT_TOKEN=
# Empty value allows all Telegram users.
ALLOWED_TELEGRAM_IDS=
AI_CREATOR_PROVIDER=
AI_GENERATION_TIMEOUT_SECONDS=120
AI_PROVIDER_TIMEOUT_SECONDS=90
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8000
# Seconds a user must wait between generation requests. Set to 0 to disable.
GENERATION_COOLDOWN_SECONDS=60
# Hard timeout (seconds) for the full generation pipeline. Protects against hangs.
GENERATION_PIPELINE_TIMEOUT_SECONDS=180
